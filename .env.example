# OpenClaw LLM Provider Configuration
# -----------------------------------
# Pick ONE provider via OPENCLAW_PROVIDER, OR set OPENCLAW_MODEL with a
# recognizable prefix (bedrock/, vertex_ai/, ollama/, openai/, anthropic/)
# and let scripts/openclaw_agent/providers.py infer the provider.
#
# Copy this file to .env and uncomment the section you need.

# OPENCLAW_PROVIDER=ollama
# OPENCLAW_PROVIDER=anthropic
# OPENCLAW_PROVIDER=openai
# OPENCLAW_PROVIDER=bedrock
# OPENCLAW_PROVIDER=vertex_ai
# OPENCLAW_PROVIDER=openclaw            # Tank-OS gateway

# --- Ollama (local; default) -------------------------------------------------
# OPENCLAW_MODEL=ollama/llama3.1:8b
# OPENCLAW_BASE_URL=http://localhost:11434

# --- Anthropic (direct) ------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENCLAW_MODEL=claude-3-5-sonnet-20241022

# --- OpenAI (direct) ---------------------------------------------------------
# OPENAI_API_KEY=sk-proj-...
# OPENCLAW_MODEL=gpt-4o

# --- AWS Bedrock -------------------------------------------------------------
# Auth uses the boto3 default credential chain:
#   env vars (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN),
#   or ~/.aws/credentials profile (set AWS_PROFILE),
#   or an attached IAM role.
# AWS_REGION_NAME=us-east-1
# AWS_PROFILE=default
# OPENCLAW_MODEL=bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Google Vertex AI --------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS must point at a service-account JSON key.
# VERTEXAI_PROJECT=your-gcp-project
# VERTEXAI_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
# OPENCLAW_MODEL=vertex_ai/gemini-1.5-pro
# OPENCLAW_MODEL=vertex_ai/claude-3-5-sonnet@20240620

# --- Tank-OS OpenClaw gateway (loopback, OpenAI-compatible) ------------------
# Run inside the Tank-OS VM (or with the gateway port forwarded to the host).
# OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
# OPENCLAW_GATEWAY_TOKEN=                # printed by `openclaw dashboard --no-open`
# OPENCLAW_MODEL=anthropic/claude-3-5-sonnet-20241022
